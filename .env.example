# Vercel / local bridge (copy to .env.local for local `vercel dev` if needed)
QUICKPREVIEW_BRIDGE_SECRET=
# Static site origin (CSS, zip links on the gated download page) — often the marketing host
QUICKPREVIEW_SITE_URL=https://quickpreview.boive.se
# Canonical Vercel origin for ticketed /api/bridge/pro-download when the portal is on another host
# QUICKPREVIEW_BRIDGE_PUBLIC_URL=https://your-project.vercel.app
# Browser CORS for POST /api/bridge/create-link-code when the portal is on another host
QUICKPREVIEW_ALLOWED_ORIGINS=https://quickpreview.boive.se
