# Vercel / local bridge (copy to .env.local for local `vercel dev` if needed)
QUICKPREVIEW_BRIDGE_SECRET=
# Static site origin (portal/support links) — often the marketing host
QUICKPREVIEW_SITE_URL=https://quickpreview.boive.se
# Canonical Vercel origin for ticketed /api/bridge/pro-download when the portal is on another host
QUICKPREVIEW_BRIDGE_PUBLIC_URL=https://quick-preview-alpha.vercel.app
# Private Vercel Blob pathname for the protected PRO DMG (served only through /api/bridge/pro-download)
QUICKPREVIEW_PRO_BLOB_PATHNAME=downloads/QuickPreviewPro.dmg
# Developer ID / notarization config for ./Scripts/build.sh package-pro
# QUICKPREVIEW_DEVELOPER_ID_APP=Developer ID Application: Your Name (TEAMID)
# QUICKPREVIEW_NOTARY_PROFILE=quickpreview-notary
# or QUICKPREVIEW_NOTARY_KEY=/path/to/AuthKey_ABC123XYZ.p8
#    QUICKPREVIEW_NOTARY_KEY_ID=ABC123XYZ
#    QUICKPREVIEW_NOTARY_ISSUER=00000000-0000-0000-0000-000000000000
# or QUICKPREVIEW_NOTARY_APPLE_ID=you@example.com
#    QUICKPREVIEW_NOTARY_TEAM_ID=TEAMID1234
#    QUICKPREVIEW_NOTARY_PASSWORD=app-specific-password
# Browser CORS for POST /api/bridge/create-link-code when the portal is on another host
QUICKPREVIEW_ALLOWED_ORIGINS=https://quickpreview.boive.se
